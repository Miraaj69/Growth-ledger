{
  "expo": {
    "name": "Growth Ledger",
    "slug": "growth-ledger",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ajaythakur69.growthledger"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ajaythakur69.growthledger"
    },
    "extra": {
      "eas": { "projectId": "6b1fa9b6-c727-446e-bc87-ad247c2f32dc" }
    },
    "owner": "nidhi2701",
    "plugins": [
      "expo-font",
      ["expo-splash-screen", {
        "backgroundColor": "#000000",
        "image": "./assets/splash.png",
        "resizeMode": "contain"
      }]
    ]
  }
}
