{
  "expo": {
    "name": "Growth Ledger",
    "slug": "growthledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080D1A",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ajaythakur69.growthledger"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080D1A"
      },
      "package": "com.ajaythakur69.growthledger"
    },
    "extra": {
      "eas": {
        "projectId": "5c1477e1-22e5-418d-bdd8-b5451ae65966"
      }
    },
    "owner": "ajaythakur69",
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080D1A",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
